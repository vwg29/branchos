// AURA OS Prisma schema.
// RULE (setup guide 5.6): NO Arabic text anywhere in this file. English comments only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Platform-level models (NOT tenant-scoped). Managed by the platform admin.
// ---------------------------------------------------------------------------

model Plan {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  priceMonthly Int      @default(0) // in minor currency units (e.g. halalas/cents)
  maxBranches  Int      @default(1)
  maxEmployees Int      @default(5)
  features     String[] @default([])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  tenants      Tenant[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "branches:write"
  group       String   @default("general")
  description String   @default("")
  createdAt   DateTime @default(now())
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserType {
  HQ
  BRANCH
  AGENCY
}

enum Industry {
  RESTAURANT
  PHARMACY
  SUPERMARKET
  FASHION
  BEAUTY
  AUTO_PARTS
  FURNITURE
}

// ---------------------------------------------------------------------------
// Tenant root. Every scoped model below points back to a Tenant via tenantId.
// ---------------------------------------------------------------------------

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  industry  Industry?    // HQ-selected industry
  status    TenantStatus @default(TRIAL)
  planId    String?
  plan      Plan?        @relation(fields: [planId], references: [id])
  createdAt DateTime     @default(now())
 
 

  users         User[]
  roles         Role[]
  regions       Region[]
  branches      Branch[]
  agencies      Agency[]
  employees     Employee[]
  tasks         Task[]
  announcements Announcement[]
  metrics       PerformanceMetric[]
  documents     Document[]
  invoices      Invoice[]
  notifications Notification[]
  settings      TenantSettings?
  communications Communication[]
  faqs          FAQ[]
}

model TenantSettings {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timezone      String   @default("Asia/Riyadh")
  currency      String   @default("IQD")
  defaultLocale String   @default("ar")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}


model Role {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  permissions String[] @default([]) // list of Permission.key values
  isOwner     Boolean  @default(false)
  createdAt   DateTime @default(now())
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email         String
  name          String
  passwordHash  String
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  userType      UserType  @default(HQ)
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])
  agencyId      String?
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  // Security fields
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime @default(now())
  // Communication relations
  sentCommunications     Communication[] @relation("SentCommunications")
  receivedCommunications Communication[] @relation("ReceivedCommunications")
  dashboardLayout        DashboardLayout?

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Region {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  branches  Branch[]
  agencies  Agency[]

  @@index([tenantId])
}

model Branch {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  regionId  String?
  region    Region?   @relation(fields: [regionId], references: [id])
  name      String
  address   String    @default("")
  phone     String    @default("")
  createdAt DateTime  @default(now())
  employees Employee[]
  tasks     Task[]
  users     User[]
  communications Communication[]

  @@index([tenantId])
}

model Agency {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  regionId  String?
  region    Region?   @relation(fields: [regionId], references: [id])
  name      String
  contact   String    @default("")
  createdAt DateTime  @default(now())
  employees Employee[]
  tasks     Task[]
  users     User[]
  communications Communication[]

  @@index([tenantId])
}

model Employee {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  name      String
  email     String   @default("")
  position  String   @default("")
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([tenantId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

model Task {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String     @default("")
  status      TaskStatus @default(TODO)
  assigneeId  String?
  assignee    Employee?  @relation(fields: [assigneeId], references: [id])
  branchId    String?
  branch      Branch?    @relation(fields: [branchId], references: [id])
  agencyId    String?
  agency      Agency?    @relation(fields: [agencyId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  @@index([tenantId])
}

model Announcement {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  body      String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model PerformanceMetric {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId  String?
  metric    String
  value     Float    @default(0)
  period    String   @default("") // e.g. "2026-07"
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Document {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  url       String   @default("")
  category  String   @default("general")
  createdAt DateTime @default(now())

  @@index([tenantId])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

model Invoice {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number    String
  amount    Int           @default(0)
  status    InvoiceStatus @default(OPEN)
  period    String        @default("")
  createdAt DateTime      @default(now())

  @@index([tenantId])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// Communication / Complaints system
model Communication {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromUserId  String?
  fromUser    User?              @relation("SentCommunications", fields: [fromUserId], references: [id])
  toUserId    String?
  toUser      User?              @relation("ReceivedCommunications", fields: [toUserId], references: [id])
  toBranchId  String?
  toBranch    Branch?            @relation(fields: [toBranchId], references: [id])
  toAgencyId  String?
  toAgency    Agency?            @relation(fields: [toAgencyId], references: [id])
  subject     String
  body        String
  priority    CommunicationPriority @default(MEDIUM)
  status      CommunicationStatus    @default(OPEN)
  category    CommunicationCategory  @default(GENERAL)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?

  @@index([tenantId])
  @@index([toUserId])
  @@index([toBranchId])
  @@index([toAgencyId])
  @@index([status])
}

enum CommunicationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommunicationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CommunicationCategory {
  GENERAL
  COMPLAINT
  ISSUE
  REQUEST
  ANNOUNCEMENT
}

// FAQ system
model FAQ {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  isPublished Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([category])
}

// Dashboard customization
model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json     // Array of widget configs: { id, type, position: {x, y, w, h}, config }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
